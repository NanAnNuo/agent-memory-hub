{
  "name": "agent-memory-hub",
  "version": "0.1.0",
  "type": "module",
  "description": "Local multi-agent archive, lightweight memory, isolated skills, and conversation export.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NanAnNuo/agent-memory-hub.git"
  },
  "bugs": {
    "url": "https://github.com/NanAnNuo/agent-memory-hub/issues"
  },
  "homepage": "https://github.com/NanAnNuo/agent-memory-hub#readme",
  "bin": {
    "agent-archive-mcp": "./dist/archive-main.js",
    "agent-orchestrator-mcp": "./dist/orchestrator-main.js",
    "agent-memory-hub": "./dist/cli.js",
    "agent-memory-hub-dashboard": "./dist/dashboard-main.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "test": "vitest run",
    "check": "npm run build && npm run test",
    "ingest": "node dist/cli.js ingest",
    "dashboard": "node dist/dashboard-main.js",
    "package:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-windows.ps1"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.30.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.10.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.21",
    "playwright": "^1.60.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
